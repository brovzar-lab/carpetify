rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Project files: only authenticated users can read/write
    // Storage rules cannot do Firestore get() calls, so ownership enforcement
    // relies on: (1) Cloud Functions validate ownership before upload,
    // (2) Frontend only constructs paths for owned projects.
    // Phase 11 can add custom claims for tighter per-project access.
    match /projects/{projectId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
