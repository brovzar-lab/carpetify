rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the user authenticated?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: is the user a member of the project?
    // Checks both ownerId (always productor) and collaborators map (invited members).
    // Per D-11: collaborators is a map field, `uid in map` checks key existence.
    function isProjectMember(projectData) {
      return request.auth.uid == projectData.ownerId
        || request.auth.uid in projectData.collaborators;
    }

    // Helper: get the user's role on a project.
    // Returns 'productor' if owner, otherwise the role string from the collaborators map.
    function getUserRole(projectData) {
      return request.auth.uid == projectData.ownerId
        ? 'productor'
        : projectData.collaborators[request.auth.uid];
    }

    // Projects: membership-based access
    match /projects/{projectId} {
      // Read: any project member can read
      allow read: if isAuth() && isProjectMember(resource.data);

      // Create: any authenticated user can create (they set themselves as owner)
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;

      // Update: any project member can update
      // Role-based write restrictions enforced in Cloud Functions and client
      allow update: if isAuth() && isProjectMember(resource.data);

      // Delete: only the project owner (productor) per D-02
      allow delete: if isAuth() && resource.data.ownerId == request.auth.uid;

      // All subcollections: inherit project-level membership check
      // Uses get() for 1 read to check parent project's membership
      match /{subcollection}/{docId} {
        allow read, write: if isAuth()
          && isProjectMember(
            get(/databases/$(database)/documents/projects/$(projectId)).data
          );
      }

      // Nested subcollections (e.g., generated/{docId}/history/{versionId})
      match /{subcollection}/{docId}/{nestedSub}/{nestedDocId} {
        allow read, write: if isAuth()
          && isProjectMember(
            get(/databases/$(database)/documents/projects/$(projectId)).data
          );
      }
    }

    // Invitations: readable by invitee (email match), writable only by Admin SDK
    match /invitations/{invitationId} {
      allow read: if isAuth()
        && resource.data.inviteeEmail == request.auth.token.email;
      allow write: if false; // Only Cloud Functions via Admin SDK can create/update invitations
    }

    // Security events: audit trail -- no client read/write per D-17
    match /security_events/{eventId} {
      allow read, write: if false; // Only Cloud Functions write
    }

    // Organizations: members can read/write
    match /organizations/{orgId} {
      allow read: if isAuth() &&
        request.auth.uid in resource.data.members;
      allow create: if isAuth();
      allow update: if isAuth() &&
        request.auth.uid in resource.data.members;
      allow delete: if false; // Organizations cannot be deleted via client

      // ERPI settings under organization
      match /erpi_settings/{settingsId} {
        allow read, write: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.members;
      }
    }

    // User profiles: users can read any profile, write only their own
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Legacy ERPI settings path (read-only fallback for migration)
    match /erpi_settings/{settingsId} {
      allow read: if isAuth();
      allow write: if false; // No writes to legacy path
    }
  }
}
